# Production Environment Variables for Docker Compose
# Copy this file to .env.prod and update with your production values

# MongoDB Configuration
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=change_this_strong_password
MONGO_URI=mongodb://admin:change_this_strong_password@mongodb:27017/taskmanagement?authSource=admin

# JWT Configuration
JWT_SECRET=generate_strong_random_secret_using_crypto_randomBytes_64_hex

# CORS Configuration
CORS_ORIGIN=https://yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Frontend Configuration
REACT_APP_API_URL=https://api.yourdomain.com/api/v1

# Rate Limiting
RATE_LIMIT=100

# Optional: External Services
# SENTRY_DSN=your_sentry_dsn
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
