NODE_ENV=production
PORT=5000

# MongoDB URI - Replace with your production MongoDB Atlas connection string
MONGO_URI=your_production_mongodb_uri_here

# JWT Secret - IMPORTANT: Generate a strong random secret for production
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_production_jwt_secret_key_generate_a_strong_random_string
JWT_EXPIRE=30d

# CORS Origin - Replace with your production frontend URL
CORS_ORIGIN=https://your-production-domain.com

# Rate Limiting (requests per 15 minutes)
RATE_LIMIT=100

# Optional: Sentry DSN for error tracking
# SENTRY_DSN=your_sentry_dsn_here
